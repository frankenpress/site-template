<?xml version="1.0"?>
<ruleset name="fp-site-template">
    <description>Coding standards for site-specific PHP (config + custom mu-plugins).</description>

    <!--
        Scope: only PHP we actually commit to the repo.
        Composer-installed plugins/themes/mu-plugins land under web/app/* on CI
        but aren't ours to lint. If you add custom code under those dirs, add
        it here explicitly (e.g. <file>web/app/mu-plugins/my-plugin</file>).
    -->
    <file>config</file>
    <file>web/app/mu-plugins/00-fp-stack.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/wp/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="ps"/>

    <rule ref="WordPress-Core">
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="WordPress.PHP.YodaConditions"/>
        <exclude name="PSR12.Files.OpenTag.NotAlone"/>
        <!-- Bedrock idiom: env( 'X' ) ?: 'default'. Allow short ternary. -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>
    </rule>

    <config name="testVersion" value="8.2-"/>
    <config name="minimum_supported_wp_version" value="6.8"/>
</ruleset>
