# FrankenPress site env — sample.
# Copy to .env for local development; production uses real env vars
# injected by your deployment (Helm chart, compose env, etc.).

# Environment: development | staging | production
WP_ENV=development

# Site URLs (no trailing slash)
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080/wp

# Database (matches docker-compose.yml defaults)
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_HOST=db

# Auth keys + salts. Generate at https://api.wordpress.org/secret-key/1.1/salt/
# or via `wp dotenv salts generate` (in a forked site).
AUTH_KEY='change-me'
SECURE_AUTH_KEY='change-me'
LOGGED_IN_KEY='change-me'
NONCE_KEY='change-me'
AUTH_SALT='change-me'
SECURE_AUTH_SALT='change-me'
LOGGED_IN_SALT='change-me'
NONCE_SALT='change-me'

# mu-plugin: S3 storage (consumed by S3UploadsBootstrap).
# Local dev points at MinIO; production at S3 / R2 / MinIO / GCS XML API.
FP_S3_BUCKET=site-media
FP_S3_KEY=minioadmin
FP_S3_SECRET=minioadmin
FP_S3_REGION=us-east-1
FP_S3_ENDPOINT=http://minio:9000
# Public URL that the BROWSER uses to fetch served media. For local dev with
# the docker-compose MinIO sidecar this is the host-published port. In
# production, point this at your CloudFront / Cloudflare / R2 / etc. CDN URL.
FP_S3_BUCKET_URL=http://localhost:9000/site-media

# mu-plugin: Souin invalidator. Default redis hostname matches docker-compose.
FP_SOUIN_REDIS_HOST=redis
FP_SOUIN_REDIS_PORT=6379

# runtime: Caddy + Souin. Same Redis as above (one cache infra serves both
# the page cache and the invalidator).
REDIS_URL=redis:6379
