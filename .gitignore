# Composer / vendor
vendor/
composer.lock

# WordPress core (composer-installed via roots/wordpress; never committed)
web/wp/

# WordPress runtime files (managed by WP, never committed)
web/app/uploads/
web/app/blogs.dir/
web/app/upgrade/
web/app/cache/
web/app/wp-cache-config.php
web/app/object-cache.php

# Composer-installed plugins / themes / mu-plugins (managed via composer.json
# and composer/installers — never committed). Custom code (your own theme or
# plugin) must be unhidden here with `!web/app/<dir>/<your-thing>/`.
web/app/plugins/*
!web/app/plugins/.gitkeep

web/app/themes/*
!web/app/themes/.gitkeep

web/app/mu-plugins/*
!web/app/mu-plugins/.gitkeep
!web/app/mu-plugins/00-fp-stack.php
!web/app/mu-plugins/s3-uploads.php

# Environment + secrets
.env
.env.*
!.env.example

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.log

# PHPUnit / static analysis
.phpunit.cache/
.phpunit.result.cache
.phpstan.cache/

# Build artefacts
build/
dist/

# Node / npm (some plugin builds use it)
node_modules/
